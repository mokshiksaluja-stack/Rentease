datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ========================================================
// ENUMS
// ========================================================

enum Role {
  TENANT
  LANDLORD
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  REJECTED
  COMPLETED
}

enum BookingPaymentStatus {
  UNPAID
  PAID
  REFUNDED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  WALLET
  BANK_TRANSFER
}

enum ReportReason {
  FAKE_LISTING
  SCAM
  INAPPROPRIATE_CONTENT
  DUPLICATE_LISTING
  OTHER
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ========================================================
// MODELS
// ========================================================

model User {
  id                   String        @id @default(uuid()) @db.Uuid
  email                String        @unique
  password             String
  name                 String
  avatar               String?       // Cloudinary URL profile photo
  role                 Role          @default(TENANT)
  isEmailVerified      Boolean       @default(false)
  verificationToken    String?
  passwordResetToken   String?
  passwordResetExpires DateTime?
  isOnline             Boolean       @default(false)
  lastSeen             DateTime?
  isSuspended          Boolean       @default(false)
  deviceToken          String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  // Relationships
  properties           Property[]    @relation("LandlordProperties")
  bookings             Booking[]     @relation("TenantBookings")
  reviews              Review[]
  notifications        Notification[]
  tenantConversations   Conversation[] @relation("TenantConversations")
  landlordConversations Conversation[] @relation("LandlordConversations")
  sentMessages         Message[]     @relation("SentMessages")
  receivedMessages     Message[]     @relation("ReceivedMessages")
  tenantPayments       Payment[]     @relation("TenantPayments")
  landlordPayments     Payment[]     @relation("LandlordPayments")
  favorites            Favorite[]
  reports              Report[]      @relation("UserReports")

  // Indexes for high performance query lookups
  @@index([email])
  @@map("users")
}

model Property {
  id            String          @id @default(uuid()) @db.Uuid
  landlordId    String          @db.Uuid
  title         String
  description   String          @db.Text
  rent          Decimal         @db.Decimal(10, 2)
  bedrooms      Int
  bathrooms     Int
  isFurnished   Boolean         @default(false)
  address       String
  city          String
  state         String
  latitude      Float
  longitude     Float
  amenities     String[]        // String array list for amenities (Pool, Gym, WiFi, etc.)
  isAvailable   Boolean         @default(true)
  isApproved    Boolean         @default(true)
  rejectedNote  String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relationships
  landlord      User            @relation("LandlordProperties", fields: [landlordId], references: [id], onDelete: Cascade)
  images        PropertyImage[]
  bookings      Booking[]
  reviews       Review[]
  favoritedBy   Favorite[]
  conversations Conversation[]

  // Indexes for location filter speedup
  @@index([landlordId])
  @@index([city, state])
  @@index([rent])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @db.Uuid
  url        String   // Cloudinary photo/video link
  orderIndex Int      @default(0) // Ordering for photo carousel display
  createdAt  DateTime @default(now())

  // Relationships
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Booking {
  id                 String               @id @default(uuid()) @db.Uuid
  bookingReference   String               @unique
  propertyId         String               @db.Uuid
  tenantId           String               @db.Uuid
  checkIn            DateTime             @db.Date
  checkOut           DateTime             @db.Date
  totalAmount        Decimal              @db.Decimal(10, 2)
  status             BookingStatus        @default(PENDING)
  paymentStatus      BookingPaymentStatus @default(UNPAID)
  paymentRequired    Boolean              @default(true)
  cancellationReason String?
  notes              String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Relationships
  property           Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant             User                 @relation("TenantBookings", fields: [tenantId], references: [id], onDelete: Cascade)
  payments           Payment[]
  timeline           BookingTimeline[]

  // DB Indexes optimized for range calculations, pagination and search
  @@index([tenantId])
  @@index([status])
  @@index([propertyId, status])
  @@index([propertyId, checkIn])
  @@index([propertyId, checkOut])
  @@map("bookings")
}

model BookingTimeline {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @db.Uuid
  status    String   // e.g. "BOOKING_CREATED", "BOOKING_APPROVED", etc.
  note      String?  @db.Text
  createdAt DateTime @default(now())

  // Relationships
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_timelines")
}

model Payment {
  id                    String        @id @default(uuid()) @db.Uuid
  bookingId             String        @db.Uuid
  tenantId              String        @db.Uuid
  landlordId            String        @db.Uuid
  stripePaymentIntentId String        @unique
  amount                Decimal       @db.Decimal(10, 2)
  currency              String        @default("usd")
  status                PaymentStatus @default(PENDING)
  paymentMethod         PaymentMethod @default(CARD)
  receiptUrl            String?
  attemptNumber         Int           @default(1)
  failureReason         String?
  processedAt           DateTime?
  refundedAt            DateTime?
  idempotencyKey        String?       @unique
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  // Relationships
  booking               Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  tenant                User          @relation("TenantPayments", fields: [tenantId], references: [id], onDelete: Cascade)
  landlord              User          @relation("LandlordPayments", fields: [landlordId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([status])
  @@map("payments")
}

model WebhookEvent {
  id            String   @id @default(uuid()) @db.Uuid
  stripeEventId String   @unique
  type          String
  processed     Boolean  @default(true)
  processedAt   DateTime @default(now())

  @@map("webhook_events")
}

model Conversation {
  id            String    @id @default(uuid()) @db.Uuid
  propertyId    String    @db.Uuid
  tenantId      String    @db.Uuid
  landlordId    String    @db.Uuid
  lastMessageId String?   @db.Uuid
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  property      Property  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant        User      @relation("TenantConversations", fields: [tenantId], references: [id], onDelete: Cascade)
  landlord      User      @relation("LandlordConversations", fields: [landlordId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([propertyId, tenantId, landlordId])
  @@index([tenantId])
  @@index([landlordId])
  @@index([propertyId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  senderId       String       @db.Uuid
  receiverId     String       @db.Uuid
  message        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  // Relationships
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver       User         @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([receiverId])
  @@index([receiverId, isRead])
  @@map("messages")
}

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  type      String   // e.g. "MESSAGE", "BOOKING_APPROVED", etc.
  title     String
  body      String
  isRead    Boolean  @default(false)
  metadata  Json?    // Optional JSON metadata for deep-linking info
  createdAt DateTime @default(now())

  // Relationships
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Review {
  id         String   @id @default(uuid()) @db.Uuid
  propertyId String   @db.Uuid
  tenantId   String   @db.Uuid
  rating     Int      // Constraint: 1 to 5
  comment    String   @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant     User     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([propertyId, tenantId]) // Tenant can write only 1 review per property
  @@index([propertyId])
  @@map("reviews")
}

model Favorite {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @db.Uuid
  propertyId String   @db.Uuid
  createdAt  DateTime @default(now())

  // Relationships
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId]) // Cannot favorite same property multiple times
  @@index([userId])
  @@map("favorites")
}

model Report {
  id          String       @id @default(uuid()) @db.Uuid
  reporterId  String       @db.Uuid
  targetType  String       // "PROPERTY" | "USER"
  targetId    String       @db.Uuid
  reason      ReportReason
  description String?      @db.Text
  status      ReportStatus @default(OPEN)
  resolvedAt  DateTime?
  createdAt   DateTime     @default(now())

  // Relationships
  reporter    User         @relation("UserReports", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([reporterId])
  @@index([targetType, targetId])
  @@map("reports")
}
